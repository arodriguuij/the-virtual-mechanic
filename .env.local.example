NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Dev-only test user used by scripts/seed.ts and lib/dashboard-data.ts while
# there's no real login (Auth.js) yet. Create it however you like (e.g. sign up
# once through Supabase Auth) and put its credentials here — never commit real
# values, only this template.
SEED_USER_EMAIL=
SEED_USER_PASSWORD=

# Strava API app (https://www.strava.com/settings/api). The redirect_uri is
# derived from the incoming request (lib/strava.ts), so it works on both
# localhost and prod without code changes — but Strava's Authorization
# Callback Domain field only holds ONE domain at a time, so you must flip it
# between `localhost` and your production domain depending on which one
# you're testing against.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
